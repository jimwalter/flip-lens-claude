{
  "manifest_version": 3,
  "name": "Flip Scout",
  "version": "1.0.0",
  "description": "Screenshot an item and instantly get Google reverse-image results, eBay sold listings, and Google Shopping — no extra clicks.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "unlimitedStorage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://google.com/*"
  ],
  "commands": {
    "capture-region": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Capture a region of the page for Flip Scout"
    }
  }
}
