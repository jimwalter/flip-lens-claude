{
  "manifest_version": 3,
  "name": "Flip Scout",
  "version": "1.0.0",
  "description": "Screenshot an item, copy it to your clipboard, and jump straight into Google Images, eBay sold listings, and Google Shopping.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://images.google.com/*", "https://www.google.com/*", "https://google.com/*"],
      "js": ["content/google-banner.js"],
      "css": ["content/google-banner.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "unlimitedStorage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://images.google.com/*",
    "https://www.google.com/*",
    "https://google.com/*"
  ],
  "commands": {
    "capture-region": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Capture a region of the page for Flip Scout"
    }
  }
}
