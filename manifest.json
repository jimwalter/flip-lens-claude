{
  "manifest_version": 3,
  "name": "Flip Scout",
  "version": "3.0.0",
  "description": "Screenshot something, then click Flip Scout (or press its shortcut) to search it on Google instantly.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "permissions": ["clipboardRead"],
  "host_permissions": ["https://www.google.com/*", "https://google.com/*"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Search the clipboard image on Google"
    }
  }
}
